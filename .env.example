# Copy this file to .env and fill in real values for local/dev use.
# Required (server refuses to start without these set to non-default values):
#   BOT_TOKEN, JWT_SECRET, JWT_REFRESH_SECRET, ADMIN_API_KEY, NODE_SECRET

NODE_ENV=development
PORT=3000

# Telegram bot
BOT_TOKEN=123456:your-telegram-bot-token
WEBHOOK_URL=
CHANNEL_ID=

# Database
MONGO_URI=mongodb://127.0.0.1:27017/vpn-panel

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=hornet:

# Auth / secrets (must be at least 32 chars for JWT secrets, 16 for NODE_SECRET)
JWT_SECRET=change-me-to-a-random-32-char-or-longer-secret
JWT_REFRESH_SECRET=change-me-to-a-different-random-32-char-or-longer-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ADMIN_API_KEY=change-me-admin-api-key
NODE_SECRET=change-me-node-secret-16ch
INTERNAL_SUB_SECRET=

# Misc backend config
PROXY_URL=
SMS_SECRET=
CARD_NUMBER=5022-2910-XXXX-XXXX
BACKEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Infra / node health monitoring
HEARTBEAT_TIMEOUT=90
FAILURE_THRESHOLD=3
HEALTH_CHECK_INTERVAL=60
LOAD_THRESHOLD=80
CRITICAL_THRESHOLD=90

# WebSocket agent bridge
WS_AGENT_PATH=/ws/agent
WS_COMMAND_TIMEOUT=30000
WS_MAX_BUFFER_SIZE=1048576

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hornet.com

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cryptomus (optional)
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_WEBHOOK_SECRET=
