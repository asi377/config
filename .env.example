# ===== SET THESE BEFORE RUNNING =====
MONGO_URI=mongodb://127.0.0.1:27017/vpn-panel
JWT_SECRET=change_this_to_64_char_random_string
JWT_REFRESH_SECRET=change_this_to_64_char_random_string
ADMIN_API_KEY=change_this_to_random_api_key
NODE_SECRET=change_this_to_32_char_min_string
SMS_SECRET=change_this_to_random_string

# ===== OPTIONAL =====
BOT_TOKEN=8693406069:AAFng7AjLG-KxsQ4d8hm0USZnUlyzkWwYA0
PROXY_URL=http://127.0.0.1:9910
BACKEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
PORT=3000
LOG_LEVEL=info

# ===== INFRASTRUCTURE =====
HEARTBEAT_TIMEOUT=90
FAILURE_THRESHOLD=3
HEALTH_CHECK_INTERVAL=60
LOAD_THRESHOLD=80
CRITICAL_THRESHOLD=90

# ===== REDIS (optional, falls back to in-memory) =====
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=hornet:

# ===== STRIPE (optional) =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== SMTP (optional) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
