{
  "name": "config-froshi",
  "version": "1.0.0",
  "description": "",
  "main": "bot.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js'",
    "seed": "node src/seed.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "admin": "echo \"Admin dashboard: http://localhost:3000/admin\"",
    "docs": "echo \"API docs: http://localhost:3000/docs\"",
    "build:admin": "cd admin-panel && npm run build && cd .. && rm -rf public/admin && mkdir -p public/admin && cp -r admin-panel/dist/* public/admin/",
    "postinstall": "npm run build:admin"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "https-proxy-agent": "^9.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "node-cron": "^4.2.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "speakeasy": "^2.0.0",
    "stripe": "^17.7.0",
    "telegraf": "^4.16.3",
    "uuid": "^11.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0"
  }
}
